<!--                                TS-02 No weekend entries-->
<!--                            </label><br>-->

<!--                            <label>-->
<!--                                <input type="checkbox" name="rules" value="TS-03" checked>-->
<!--                                TS-03 No public holiday entries-->
<!--                            </label><br>-->

<!--                            <label>-->
<!--                                <input type="checkbox" name="rules" value="TS-04" checked>-->
<!--                                TS-04 Hours must be positive-->
<!--                            </label><br>-->

<!--                            <label>-->
<!--                                <input type="checkbox" name="rules" value="TS-05" checked>-->
<!--                                TS-05 Resource must be in roster-->
<!--                            </label><br>-->

<!--                            <label>-->
<!--                                <input type="checkbox" name="rules" value="TS-06" checked>-->
<!--                                TS-06 SOW must match expected-->
<!--                            </label><br>-->

<!--                            <label>-->
<!--                                <input type="checkbox" name="rules" value="TS-07" checked>-->
<!--                                TS-07 Date within engagement period-->
<!--                            </label><br>-->

<!--                            <label>-->
<!--                                <input type="checkbox" name="rules" value="TS-08" checked>-->
<!--                                TS-08 All fields are mandatory-->
<!--                            </label>-->

<!--                        </div>-->
<!--                    </div>-->

                    <div id="ruleValidationError"
                         class="alert alert-danger"
                         style="display:none; margin-top:10px;">
                        <i class="fa fa-circle-xmark"></i>
                        Please select at least one validation rule.
                    </div>

<!--                    <button type="submit"-->
<!--                            id="uploadBtn"-->
<!--                            class="btn btn-success btn-block"-->
<!--                            disabled>-->
<!--                        <i class="fa fa-rocket"></i>-->
<!--                        Upload & Validate-->
<!--                    </button>-->

<!--                    <div class="drop-zone" id="dropZone">-->
<!--                        <i class="fa fa-file-excel fa-3x text-green"></i>-->
<!--                        <p class="mt-2">Drag &amp; drop your <strong>.xlsx</strong> here</p>-->
<!--                        <p class="text-muted small">or click to browse</p>-->
<!--                        <input type="file" id="fileInput" accept=".xlsx" style="display:none"/>-->
<!--                        <p id="fileName" class="mt-2 selected-file"></p>-->
<!--                    </div>-->


                    <button type="submit"
                            id="uploadBtn"
                            class="btn-upload"
                            disabled>
                        <i class="fa fa-shield-halved"></i>
                        Upload & Validate
                    </button>


                </form>


            </div>
        </div>

        <!-- ── Master Data Summary ──────────────────────────────────────── -->
        <div>
            <div class="card mb-3">
                <div class="card-header"><i class="fa fa-calendar-xmark"></i> Company Holidays Configured</div>
                <div class="card-body p-0">
                    <table class="data-table">
                        <thead><tr><th>Date</th><th>Holiday</th><th>Country</th></tr></thead>
                        <tbody>
                        <tr th:each="h : ${holidays}">
                            <td><span class="badge badge-orange" th:text="${h.holidayDate}"></span></td>
                            <td th:text="${h.holidayName}">-</td>
                            <td th:text="${h.countryCode}">IN</td>
                        </tr>
                        </tbody>
                    </table>
                    <div th:if="${#lists.isEmpty(holidays)}" class="empty-state small">
                        <p>No holidays configured. Edit <code>application.yml</code> → <code>app.master.holidays</code></p>
                    </div>
                </div>
            </div>
<!--            <div class="card">-->
<!--                <div class="card-header">-->
<!--                    <i class="fa fa-users"></i> Roster-->
<!--                    <span class="badge badge-blue ml-2" th:text="${resourceCount} + ' resources'"></span>-->
<!--                </div>-->
<!--                <div class="card-body">-->
<!--                    <p class="text-muted small">-->
<!--                        <i class="fa fa-circle-info"></i>-->
<!--                        Edit <code>app.master.resources</code> in <code>application.yml</code> and restart to update.-->
<!--                    </p>-->
<!--                </div>-->
            </div>
        </div>
    </div>

    <!-- ── Upload History ───────────────────────────────────────────────── -->
    <div class="card mt-4">
        <div class="card-header"><i class="fa fa-history"></i> Upload History</div>
        <div class="card-body p-0">
            <div th:if="${#lists.isEmpty(sessions)}" class="empty-state">
                <i class="fa fa-inbox fa-3x"></i>
                <p>No uploads yet. Upload an Excel file above to get started.</p>
            </div>
            <table th:if="${!#lists.isEmpty(sessions)}" class="data-table">
                <thead>
                <tr><th>Session</th><th>File</th><th>Sheets</th><th>Uploaded</th><th>Status</th><th></th></tr>
                </thead>
                <tbody>
                <tr th:each="s : ${sessions}">
                    <td><code th:text="${#strings.substring(s.sessionId,0,8) + '…'}"></code></td>
                    <td><i class="fa fa-file-excel text-green"></i> <span th:text="${s.fileName}"></span></td>
                    <td th:text="${s.sheetCount}">0</td>
                    <td th:text="${#temporals.format(s.uploadedAt,'dd-MMM-yyyy HH:mm')}">-</td>
                    <td>
                        <span th:class="${s.status == 'PARSED'} ? 'badge badge-green' : 'badge badge-gray'"
                              th:text="${s.status}">-</span>
                    </td>
                    <td>
                        <a th:href="@{/view/{id}(id=${s.sessionId})}" class="btn btn-sm btn-primary">
                            <i class="fa fa-eye"></i> View
                        </a>
                    </td>
                </tr>
                </tbody>
            </table>
        </div>
    </div>
</main>

