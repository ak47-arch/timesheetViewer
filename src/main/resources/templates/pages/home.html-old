<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" lang="en">
<head th:replace="fragments/layout :: head('Home')"></head>
<body>
<nav th:replace="fragments/layout :: navbar"></nav>

<main class="main-content">
    <div class="page-header">
        <div>
            <h1><i class="fa fa-file-excel"></i> Excel Timesheet Viewer &amp; Validator</h1>
            <p class="subtitle">Upload any Excel workbook to view all sheets in tabs.
                Automatically validates the <strong>Timesheet</strong> sheet against
                business rules.</p>
        </div>
    </div>

    <!-- Flash messages -->
    <div th:if="${success}" class="alert alert-success">
        <i class="fa fa-circle-check"></i> <span th:text="${success}"></span>
    </div>
    <div th:if="${error}" class="alert alert-danger">
        <i class="fa fa-circle-xmark"></i> <span th:text="${error}"></span>
    </div>
    <div th:if="${warning}" class="alert alert-warning">
        <i class="fa fa-triangle-exclamation"></i> <span th:text="${warning}"></span>
    </div>

    <div class="two-col">
        <!-- ── Upload Card ───────────────────────────────────────────────── -->
        <div class="card">
            <div class="card-header">
                <i class="fa fa-upload"></i> Upload Excel Workbook
            </div>
            <div class="card-body">
                <div class="drop-zone" id="dropZone">
                    <i class="fa fa-file-excel fa-3x text-green"></i>
                    <p class="mt-2">Drag &amp; drop your <strong>.xlsx</strong> here</p>
                    <p class="text-muted small">or click to browse</p>
                    <input type="file" id="fileInput" accept=".xlsx" style="display:none"/>
                    <p id="fileName" class="mt-2 selected-file"></p>
                </div>
                <form id="uploadForm"
                      th:action="@{/upload}"
                      method="post"
                      enctype="multipart/form-data"
                      class="mt-3">

                    <input type="file"
                           name="file"
                           id="hiddenFile"
                           accept=".xlsx"
                           style="display:none"/>


                    <div class="validation-card mt-3 mb-3">

                        <div class="validation-header">

                            <div>
                                <h3>
                                    <i class="fa fa-sliders"></i>
                                    Validation Rules
                                    <span class="rule-count-badge">
                                        <span id="selectedRuleCount">8</span> Selected
                                    </span>
                                </h3>

                                <div class="validation-subtitle">
                                    Only selected rules will be applied during validation.
                                </div>
                            </div>

<!--                            <div class="validation-actions">-->

<!--                                <button type="button"-->
<!--                                        class="btn btn-sm btn-primary"-->
<!--                                        onclick="selectAllRules()">-->
<!--                                    Select All-->
<!--                                </button>-->

<!--                                <button type="button"-->
<!--                                        class="btn btn-sm btn-secondary"-->
<!--                                        onclick="clearAllRules()">-->
<!--                                    Clear All-->
<!--                                </button>-->

<!--                            </div>-->

                            <div class="rule-actions">
                                <a href="javascript:void(0)"
                                   onclick="selectAllRules()"
                                   class="rule-action-link">
                                    <i class="fa fa-square-check"></i> Select All
                                </a>

                                <span class="rule-divider">|</span>

                                <a href="javascript:void(0)"
                                   onclick="clearAllRules()"
                                   class="rule-action-link">
                                    <i class="fa fa-xmark"></i> Clear All
                                </a>
                            </div>

                        </div>

                        <div class="validation-list rule-tabset" id="ruleGroups">

                            <div class="rule-group"
                                 th:each="grp : ${ruleGroups}"
                                 th:classappend="${grp.alwaysOn} ? ' rule-group-locked' : ''"
                                 th:attr="data-sheet=${grp.sheetName},data-locked=${grp.alwaysOn}">

                                <div class="rule-group-head">
                                    <div class="rule-group-title">
                                        <i class="fa fa-table-list"></i>
                                        <span th:text="${grp.sheetName}">Sheet</span>
                                        <span class="rule-group-meta"
                                              th:text="${#lists.size(grp.rules)} + ' rules'">rules</span>
                                    </div>

                                    <!-- Toggleable groups get a master switch + live count -->
                                    <label th:if="${!grp.alwaysOn}" class="rule-group-toggle">
                                        <input type="checkbox"
                                               class="rule-group-master"
                                               checked
                                               onchange="toggleGroup(this)">
                                        <span class="rule-group-count">
                                            <span class="grp-selected">0</span>/<span
                                                th:text="${#lists.size(grp.rules)}">0</span>
                                        </span>
                                    </label>

                                    <!-- Always-on groups show a static badge -->
                                    <span th:if="${grp.alwaysOn}" class="always-on-pill"
                                          title="These checks run automatically whenever this sheet is present">
                                        <i class="fa fa-lock"></i> Always applied
                                    </span>
                                </div>

                                <div class="rule-group-body">
                                    <label class="rule-row"
                                           th:each="r : ${grp.rules}"
                                           th:classappend="${grp.alwaysOn} ? ' rule-row-locked' : ''">

                                        <input type="checkbox"
                                               name="rules"
                                               th:value="${r.id}"
                                               th:checked="${!grp.alwaysOn}"
                                               th:disabled="${grp.alwaysOn}">

                                        <span class="rule-badge" th:text="${r.id}">TS-01</span>
                                        <span class="rule-text" th:text="${r.description}">rule</span>

                                        <span th:classappend="${r.severity == 'CRITICAL'} ? ' sev-critical' : ' sev-warning'"
                                              class="sev-tag"
                                              th:text="${r.severity}">CRITICAL</span>
                                    </label>
                                </div>
                            </div>

                        </div>

                    </div>

<!--                    <div class="info-box mt-3">-->

<!--                        <div style="display:flex;justify-content:space-between;align-items:center;">-->
<!--                            <strong>Validation Rules</strong>-->

<!--                            <div>-->
<!--                                <button type="button"-->
<!--                                        class="btn btn-sm btn-secondary"-->
<!--                                        onclick="selectAllRules()">-->
