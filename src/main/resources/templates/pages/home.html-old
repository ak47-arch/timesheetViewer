<div th:replace="fragments/layout :: global-loader"></div>
<footer th:replace="fragments/layout :: footer"></footer>

<script th:src="@{/js/app.js}"></script>

<script>

    // Count only enabled (toggleable) rules — disabled "always applied"
    // checkboxes are never submitted and never counted.
    function enabledRuleBoxes() {
        return Array.from(
            document.querySelectorAll('input[name="rules"]')
        ).filter(cb => !cb.disabled);
    }

    function updateUploadButtonState() {

    const checkedRules =
        enabledRuleBoxes().filter(cb => cb.checked).length;

    const fileSelected =
        document.getElementById("hiddenFile").files.length > 0;

    const uploadBtn =
        document.getElementById("uploadBtn");

    const errorBox =
        document.getElementById("ruleValidationError");

    if (checkedRules === 0) {

        errorBox.style.display = "block";

    } else {

        errorBox.style.display = "none";
    }

    uploadBtn.disabled =
        (checkedRules === 0 || !fileSelected);
}

// Refresh each group's "selected/total" count and its master switch.
function updateGroupStates() {
    document.querySelectorAll('#ruleGroups .rule-group').forEach(group => {
        const boxes  = group.querySelectorAll('input[name="rules"]:not([disabled])');
        if (boxes.length === 0) return; // always-on group, nothing to sync
        const checked = group.querySelectorAll('input[name="rules"]:not([disabled]):checked').length;

        const countEl = group.querySelector('.grp-selected');
        if (countEl) countEl.textContent = checked;

        const master = group.querySelector('.rule-group-master');
        if (master) {
            master.checked       = checked === boxes.length;
            master.indeterminate = checked > 0 && checked < boxes.length;
        }
    });
}

// Master switch on a group header: check/uncheck all rules in that group.
function toggleGroup(master) {
    const group = master.closest('.rule-group');
    group.querySelectorAll('input[name="rules"]:not([disabled])')
        .forEach(cb => cb.checked = master.checked);
    updateRuleCount();
}

function updateRuleCount() {

    const checked =
        enabledRuleBoxes().filter(cb => cb.checked).length;

    document.getElementById(
        'selectedRuleCount'
    ).textContent = checked;

    updateGroupStates();
    if (window.refreshRuleTabCounts) refreshRuleTabCounts();
    updateUploadButtonState();
}



<!--    function updateRuleCount() {-->
<!--        const checked =-->
<!--            document.querySelectorAll('input[name="rules"]:checked').length;-->

<!--        document.getElementById('selectedRuleCount').textContent = checked;-->
<!--    }-->


<!--    function updateRuleCount() {-->

<!--    const checked =-->
<!--        document.querySelectorAll(-->
<!--            'input[name="rules"]:checked'-->
<!--        ).length;-->

<!--    document.getElementById(-->
<!--        'selectedRuleCount'-->
<!--    ).textContent = checked;-->

<!--    const uploadBtn =-->
<!--        document.getElementById("uploadBtn");-->

<!--    const errorBox =-->
<!--        document.getElementById("ruleValidationError");-->

<!--    if (checked === 0) {-->

<!--        uploadBtn.disabled = true;-->

<!--        errorBox.style.display = "block";-->

<!--    } else {-->

<!--        uploadBtn.disabled = false;-->

<!--        errorBox.style.display = "none";-->
<!--    }-->
<!--}-->

    function selectAllRules() {
        enabledRuleBoxes().forEach(cb => cb.checked = true);
        updateRuleCount();
    }

    function clearAllRules() {
        enabledRuleBoxes().forEach(cb => cb.checked = false);
        updateRuleCount();
    }

    document.addEventListener('DOMContentLoaded', function () {

        document.querySelectorAll('input[name="rules"]')
            .forEach(cb => {
                cb.addEventListener('change', updateRuleCount);
            });

        document.getElementById("hiddenFile")
    .addEventListener("change", updateUploadButtonState);

        updateRuleCount();
    });

<!--    loader JS-->
    let uploadInProgress = false;

    document
    .getElementById("uploadForm")
    .addEventListener("submit", function (e) {

        if(uploadInProgress){

            e.preventDefault();
            return;
        }

        uploadInProgress = true;

        const uploadBtn =
            document.getElementById("uploadBtn");

        uploadBtn.disabled = true;

        uploadBtn.innerHTML =
            '<i class="fa fa-spinner fa-spin"></i> Processing...';

<!--        document-->
<!--            .getElementById("uploadLoader")-->
<!--            .style.display = "flex";-->

        showLoader(
    "Uploading Workbook",
    "Validating selected rules..."
);
        });



</script>

