<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ── EXISTING TABLES ──────────────────────────────────────────────── -->

    <changeSet id="001-upload-session" author="xyzsoft">
        <createTable tableName="UPLOAD_SESSION">
            <column name="ID"          type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="SESSION_ID"  type="VARCHAR(36)"><constraints nullable="false" unique="true"/></column>
            <column name="FILE_NAME"   type="VARCHAR(255)"/>
            <column name="UPLOADED_AT" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="SHEET_COUNT" type="INT"/>
            <column name="STATUS"      type="VARCHAR(20)"/>
        </createTable>
    </changeSet>

    <changeSet id="001-sheet-meta" author="xyzsoft">
        <createTable tableName="SHEET_META">
            <column name="ID"          type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="SESSION_ID"  type="VARCHAR(36)"><constraints nullable="false"/></column>
            <column name="SHEET_NAME"  type="VARCHAR(100)"/>
            <column name="SHEET_INDEX" type="INT"/>
            <column name="ROW_COUNT"   type="INT"/>
            <column name="COL_COUNT"   type="INT"/>
        </createTable>
    </changeSet>

    <changeSet id="001-cell-data" author="xyzsoft">
        <createTable tableName="CELL_DATA">
            <column name="ID"            type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="SESSION_ID"    type="VARCHAR(36)"><constraints nullable="false"/></column>
            <column name="SHEET_NAME"    type="VARCHAR(100)"/>
            <column name="ROW_IDX"       type="INT"/>
            <column name="COL_IDX"       type="INT"/>
            <column name="DISPLAY_VALUE" type="VARCHAR(2000)"/>
            <column name="RAW_VALUE"     type="VARCHAR(2000)"/>
            <column name="FORMULA"       type="VARCHAR(2000)"/>
            <column name="CELL_TYPE"     type="VARCHAR(20)"/>
            <column name="IS_HEADER"     type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
        <createIndex tableName="CELL_DATA" indexName="IDX_CELL_SESSION_SHEET">
            <column name="SESSION_ID"/>
            <column name="SHEET_NAME"/>
        </createIndex>
    </changeSet>

    <changeSet id="001-validation-issue" author="xyzsoft">
        <createTable tableName="VALIDATION_ISSUE">
            <column name="ID"         type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="SESSION_ID" type="VARCHAR(36)"><constraints nullable="false"/></column>
            <column name="RULE_ID"    type="VARCHAR(20)"/>
            <column name="SEVERITY"   type="VARCHAR(10)"/>
            <column name="SHEET_NAME" type="VARCHAR(100)"/>
            <column name="ROW_IDX"    type="INT"/>
            <column name="COL_IDX"    type="INT"/>
            <column name="FIELD_NAME" type="VARCHAR(50)"/>
            <column name="MESSAGE"    type="VARCHAR(1000)"/>
        </createTable>
    </changeSet>

    <changeSet id="001-public-holiday" author="xyzsoft">
        <createTable tableName="PUBLIC_HOLIDAY">
            <column name="ID"           type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="HOLIDAY_DATE" type="DATE"><constraints nullable="false"/></column>
            <column name="HOLIDAY_NAME" type="VARCHAR(100)"/>
            <column name="COUNTRY_CODE" type="VARCHAR(5)"/>
            <column name="NOTES"        type="VARCHAR(500)"/>
        </createTable>
    </changeSet>

    <changeSet id="001-resource" author="xyzsoft">
        <createTable tableName="RESOURCE">
            <column name="ID"             type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="RESOURCE_ID"    type="VARCHAR(20)"><constraints nullable="false" unique="true"/></column>
            <column name="NAME"           type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="DAILY_RATE_USD" type="DECIMAL(10,2)"/>
            <column name="START_DATE"     type="DATE"/>
            <column name="END_DATE"       type="DATE"/>
        </createTable>
    </changeSet>

    <!-- ── Security: ROLES ──────────────────────────────────────────────── -->
    <changeSet id="002-role" author="xyzsoft">
        <createTable tableName="ROLE">
            <column name="ID"          type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="NAME"        type="VARCHAR(30)"><constraints nullable="false" unique="true"/></column>
            <column name="DESCRIPTION" type="VARCHAR(200)"/>
        </createTable>
    </changeSet>

    <!-- ── Security: USERS ──────────────────────────────────────────────── -->
    <changeSet id="002-app-user" author="xyzsoft">
        <createTable tableName="APP_USER">
            <column name="ID"          type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="USERNAME"    type="VARCHAR(60)"><constraints nullable="false" unique="true"/></column>
            <column name="PASSWORD"    type="VARCHAR(200)"><constraints nullable="false"/></column>
            <column name="FULL_NAME"   type="VARCHAR(100)"/>
            <column name="EMAIL"       type="VARCHAR(150)"/>
            <column name="ENABLED"     type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="RESOURCE_ID" type="VARCHAR(20)"/>
            <column name="CREATED_AT"  type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <!-- ── Security: USER_ROLE join ─────────────────────────────────────── -->
    <changeSet id="002-user-role" author="xyzsoft">
        <createTable tableName="USER_ROLE">
            <column name="USER_ID" type="BIGINT"><constraints nullable="false"/></column>
            <column name="ROLE_ID" type="BIGINT"><constraints nullable="false"/></column>
        </createTable>
        <addPrimaryKey tableName="USER_ROLE" columnNames="USER_ID,ROLE_ID"
                       constraintName="PK_USER_ROLE"/>
    </changeSet>

    <!-- ── TIMESHEET_ENTRY — complete definition including override columns ─ -->
    <!--
        IMPORTANT: This changeSet contains ALL columns for TIMESHEET_ENTRY.
        The WEEKEND_OVERRIDE and WEEKEND_OVERRIDE_REASON columns MUST be here.
        Because H2 is in-memory, Liquibase runs the full set on every startup
        from scratch — there is no migration history. If you see
        "missing column [weekend_override]", it means the entity has the fields
        but this DDL was missing them. Fixed by having one complete changeSet.
    -->
    <changeSet id="002-timesheet-entry" author="xyzsoft">
        <createTable tableName="TIMESHEET_ENTRY">
            <column name="ID"                     type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="RESOURCE_NAME"           type="VARCHAR(100)"><constraints nullable="false"/></column>
            <column name="ENTRY_DATE"             type="DATE"><constraints nullable="false"/></column>
            <column name="ASSIGNED_TEAM"          type="VARCHAR(10)"/>
            <column name="PROJECT"                type="VARCHAR(100)"/>
            <column name="SUB_PROJECT"            type="VARCHAR(100)"/>
            <column name="PROJECT_CODE"           type="VARCHAR(50)"/>
            <column name="COUNTRY_CODE"           type="VARCHAR(5)"/>
            <column name="HOURS"                  type="DECIMAL(4,2)"><constraints nullable="false"/></column>
            <column name="TASK"                   type="VARCHAR(1000)"/>
            <column name="COMPANY"                type="VARCHAR(100)"/>
            <column name="SOW"                    type="VARCHAR(50)"/>
            <column name="SUBMITTED_BY"           type="VARCHAR(60)"/>
            <column name="SUBMITTED_AT"           type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="STATUS"                 type="VARCHAR(30)" defaultValue="SUBMITTED"/>
            <!-- Weekend override provision — added to allow logging on weekends with reason -->
            <column name="WEEKEND_OVERRIDE"       type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="WEEKEND_OVERRIDE_REASON" type="VARCHAR(500)"/>
        </createTable>
        <createIndex tableName="TIMESHEET_ENTRY" indexName="IDX_TE_RESOURCE_DATE">
            <column name="RESOURCE_NAME"/>
            <column name="ENTRY_DATE"/>
        </createIndex>
    </changeSet>


    <!-- ── SOW master table ─────────────────────────────────────────────── -->
    <changeSet id="003-sow-master" author="xyzsoft">
        <createTable tableName="SOW_MASTER">
            <column name="ID"          type="BIGINT" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="SOW_NUMBER"  type="VARCHAR(50)"><constraints nullable="false" unique="true"/></column>
            <column name="PO_NUMBER"   type="VARCHAR(50)"/>
            <column name="PO_VALUE"    type="DECIMAL(15,2)"/>
            <column name="CLIENT"      type="VARCHAR(100)"/>
            <column name="DESCRIPTION" type="VARCHAR(500)"/>
            <column name="START_DATE"  type="DATE"/>
            <column name="END_DATE"    type="DATE"/>
            <column name="ACTIVE"      type="BOOLEAN" defaultValueBoolean="true"/>
        </createTable>
    </changeSet>

    <!-- ── Resource ↔ SOW mapping (many-to-many) ───────────────────────── -->
    <changeSet id="003-resource-sow" author="xyzsoft">
        <createTable tableName="RESOURCE_SOW">
            <column name="RESOURCE_ID" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="SOW_NUMBER"  type="VARCHAR(50)"><constraints nullable="false"/></column>
            <column name="ROLE_IN_SOW" type="VARCHAR(100)"/>
        </createTable>
        <addPrimaryKey tableName="RESOURCE_SOW"
                       columnNames="RESOURCE_ID,SOW_NUMBER"
                       constraintName="PK_RESOURCE_SOW"/>
    </changeSet>

</databaseChangeLog>
